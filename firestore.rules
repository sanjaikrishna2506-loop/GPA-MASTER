rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: userProfiles
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - targetCGPA: number (optional, 0-10)
    //   - displayName: string (optional)
    //
    // Collection: semesterGrades
    // Document ID: {uid}_{semester}
    // Fields:
    //   - uid: string (required)
    //   - semester: string (required)
    //   - grades: map (required) - courseCode to grade string
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidGrade(grade) {
      return grade in ['O', 'A+', 'A', 'B+', 'B', 'C', 'U', ''];
    }

    function isValidSemesterGrades(data) {
      return data.uid is string &&
             data.semester is string &&
             data.grades is map;
    }

    function isValidUserProfile(data) {
      return data.uid is string &&
             (!('targetCGPA' in data) || (data.targetCGPA is number && data.targetCGPA >= 0 && data.targetCGPA <= 10)) &&
             (!('displayName' in data) || data.displayName is string);
    }

    // Rules
    match /userProfiles/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidUserProfile(request.resource.data);
    }

    match /semesterGrades/{gradeId} {
      allow read: if isAuthenticated() && (gradeId.startsWith(request.auth.uid + "_") || (resource != null && resource.data.uid == request.auth.uid));
      allow create, update: if isAuthenticated() && 
                             request.resource.data.uid == request.auth.uid &&
                             gradeId.startsWith(request.auth.uid + "_") &&
                             isValidSemesterGrades(request.resource.data);
      allow delete: if isAuthenticated() && (gradeId.startsWith(request.auth.uid + "_") || (resource != null && resource.data.uid == request.auth.uid));
    }
  }
}
